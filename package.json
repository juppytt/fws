{
  "name": "@juppytt/fws",
  "version": "0.3.0",
  "description": "Fake Web Services — local mock server for testing CLI tools and agents without real credentials",
  "type": "module",
  "bin": {
    "fws": "bin/fws-cli.js"
  },
  "scripts": {
    "start": "tsx bin/fws.ts server start",
