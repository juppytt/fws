{
  "name": "@juppytt/fws",
  "version": "0.3.1",
  "description": "Fake Web Services — local mock server for testing CLI tools and agents without real credentials",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juppytt/fws.git"
  },
  "homepage": "https://github.com/juppytt/fws#readme",
  "bugs": {
    "url": "https://github.com/juppytt/fws/issues"
  },
  "bin": {
    "fws": "bin/fws-cli.js"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "README.md"
  ],
  "scripts": {
    "start": "tsx bin/fws.ts server start",
    "build": "tsc",
    "dev": "tsx bin/fws.ts",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:watch": "vitest",
    "prepublishOnly": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "express": "^5.1.0",
    "nanoid": "^5.1.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
